@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:    <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix bibo:  <http://purl.org/ontology/bibo/> .
@prefix :      <http://example.org/dh-ontology#> .

<http://example.org/dh-ontology>
    a owl:Ontology ;
    rdfs:label "数字人文文献本体"@zh ;
    rdfs:label "Digital Humanities Literature Ontology"@en ;
    rdfs:comment "针对CNKI数字人文主题期刊论文的元数据本体，复用Dublin Core、FOAF、BIBO"@zh ;
    owl:versionInfo "1.0" ;
    dc:creator "基于Ontology Development 101方法论设计" .

# ============================================================
# 第1层：类定义 (Class Hierarchy)
# ============================================================

# --- 论文 ---
:Article a owl:Class ;
    rdfs:label "论文"@zh ;
    rdfs:label "Article"@en ;
    rdfs:comment "一篇学术期刊论文"@zh ;
    rdfs:subClassOf bibo:AcademicArticle ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty dc:title ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty dc:creator ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] .

# --- 人（作者）---
:Person a owl:Class ;
    rdfs:label "人"@zh ;
    rdfs:label "Person"@en ;
    rdfs:comment "论文作者"@zh ;
    rdfs:subClassOf foaf:Person .

# --- 机构（作者单位）---
:Organization a owl:Class ;
    rdfs:label "机构"@zh ;
    rdfs:label "Organization"@en ;
    rdfs:comment "作者所属机构"@zh ;
    rdfs:subClassOf foaf:Organization .

# --- 期刊 ---
:Journal a owl:Class ;
    rdfs:label "期刊"@zh ;
    rdfs:label "Journal"@en ;
    rdfs:comment "论文发表的期刊"@zh ;
    rdfs:subClassOf bibo:Journal .

# --- 关键词 ---
:Keyword a owl:Class ;
    rdfs:label "关键词"@zh ;
    rdfs:label "Keyword"@en ;
    rdfs:comment "论文关键词，独立为类以便作为语义实体查询"@zh .

# ============================================================
# 第2层：对象属性 (Object Properties) — 指向其他实体
# ============================================================

# --- 作者（复用 dc:creator）---
# :Article → dc:creator → :Person
# 注意：dc:creator 本身定义在 Dublin Core 中，这里仅声明使用
dc:creator a owl:ObjectProperty .

# --- 关键词（复用 dc:subject）---
# :Article → dc:subject → :Keyword
dc:subject a owl:ObjectProperty .

# --- 所属机构 ---
:publisher a owl:ObjectProperty ;
    rdfs:label "所属机构"@zh ;
    rdfs:label "publisher"@en ;
    rdfs:comment "作者/论文所属的机构"@zh ;
    rdfs:domain :Article ;
    rdfs:range :Organization ;
    rdfs:subPropertyOf dc:publisher .

# --- 发表在 ---
:publishedIn a owl:ObjectProperty ;
    rdfs:label "发表在"@zh ;
    rdfs:label "published in"@en ;
    rdfs:comment "论文发表的期刊"@zh ;
    rdfs:domain :Article ;
    rdfs:range :Journal ;
    rdfs:subPropertyOf dcterms:isPartOf .

# ============================================================
# 第3层：数据属性 (Datatype Properties) — 指向字面量
# ============================================================

# --- 标题（复用 dc:title）---
# 值域：xsd:string，定义域已通过 Article 的约束声明

# --- 摘要（复用 dcterms:abstract）---
# 值域：xsd:string

# --- 发表日期（复用 dcterms:issued）---
# 值域：xsd:date

# --- 唯一标识（复用 dc:identifier）---
# 值域：xsd:string（DOI）

# --- 网址链接 ---
:cnkiUrl a owl:DatatypeProperty ;
    rdfs:label "知网链接"@zh ;
    rdfs:label "CNKI URL"@en ;
    rdfs:comment "论文在知网的访问链接"@zh ;
    rdfs:domain :Article ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf dcterms:references .

# --- CNKI 内部序号 ---
:cnkiId a owl:DatatypeProperty ;
    rdfs:label "CNKI序号"@zh ;
    rdfs:label "CNKI ID"@en ;
    rdfs:comment "CNKI导出的内部序号（1-100）"@zh ;
    rdfs:domain :Article ;
    rdfs:range xsd:integer .

# --- 来源库 ---
:srcDatabase a owl:DatatypeProperty ;
    rdfs:label "来源库"@zh ;
    rdfs:label "source database"@en ;
    rdfs:comment "CNKI来源库类型（如：期刊、硕士、博士）"@zh ;
    rdfs:domain :Article ;
    rdfs:range xsd:string .

# --- 关键词标签（字面量版本，用于 dc:subject 的简单场景）---
:keywordLabel a owl:DatatypeProperty ;
    rdfs:label "关键词标签"@zh ;
    rdfs:comment "关键词的字面量表示"@zh ;
    rdfs:domain :Keyword ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf rdfs:label .

# ============================================================
# 第4层：值域/定义域声明（显式声明复用的 DC 属性约束）
# ============================================================

# 虽然 dc:title 等属性本身在 DC 中已有定义，这里显式声明其在本文本体中的上下文
[] a owl:Axiom ;
    owl:annotatedProperty dc:title ;
    owl:annotatedSource :Article ;
    owl:annotatedTarget rdfs:Literal ;
    rdfs:comment "在本体中，dc:title 的主语是 Article，宾语是文字"@zh .

[] a owl:Axiom ;
    owl:annotatedProperty dc:creator ;
    owl:annotatedSource :Article ;
    owl:annotatedTarget :Person ;
    rdfs:comment "在本体中，dc:creator 连接 Article 和 Person"@zh .

[] a owl:Axiom ;
    owl:annotatedProperty dc:subject ;
    owl:annotatedSource :Article ;
    owl:annotatedTarget :Keyword ;
    rdfs:comment "在本体中，dc:subject 连接 Article 和 Keyword"@zh .
